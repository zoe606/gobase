# ===========================================
# Application Configuration
# ===========================================

# App
APP_NAME=go-boilerplate
APP_VERSION=1.0.0
APP_ENV=development

# ===========================================
# HTTP Server Configuration
# ===========================================

HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_REQUEST_TIMEOUT=30s

# ===========================================
# Logging Configuration
# ===========================================

# Options: debug, info, warn, error
LOG_LEVEL=debug

# ===========================================
# PostgreSQL Database Configuration
# ===========================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DBNAME=app
# PRODUCTION: Must be 'require', 'verify-ca', or 'verify-full' (validated at startup)
POSTGRES_SSLMODE=disable
POSTGRES_MAX_POOL_SIZE=10

# ===========================================
# Redis Configuration
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# JWT Configuration
# ===========================================

# IMPORTANT: Change this in production!
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ===========================================
# CORS Configuration
# ===========================================

# PRODUCTION: Set to specific origins (e.g., https://app.example.com) — wildcard triggers a warning
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Request-ID
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400

# ===========================================
# Rate Limiting Configuration
# ===========================================

# Max requests per IP within the expiration window
RATE_LIMIT_MAX=100
RATE_LIMIT_EXPIRATION=1m

# ===========================================
# Asynq Background Jobs Configuration
# ===========================================

# Number of concurrent workers
ASYNQ_CONCURRENCY=10
# Max retry attempts before archiving failed tasks (default: 3)
ASYNQ_MAX_RETRY=3

# ===========================================
# Feature Flags
# ===========================================

METRICS_ENABLED=true
SWAGGER_ENABLED=true

# ===========================================
# Email Service Configuration
# ===========================================

# Provider: resend, brevo (default: resend)
EMAIL_PROVIDER=resend
# Get your API key from https://resend.com or https://www.brevo.com
EMAIL_API_KEY=
EMAIL_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=Go Boilerplate

# ===========================================
# Storage Configuration
# ===========================================

# Driver: local, s3 (default: s3)
STORAGE_DRIVER=s3
# Max upload size in bytes (default: 10MB)
STORAGE_MAX_SIZE=10485760

# Local Storage (when STORAGE_DRIVER=local)
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_URL=http://localhost:8080/uploads

# S3/MinIO Storage (when STORAGE_DRIVER=s3)
STORAGE_S3_ENDPOINT=localhost:9000
STORAGE_S3_BUCKET=app-uploads
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin
# PRODUCTION: Consider enabling SSL for S3 connections (warning logged if false)
STORAGE_S3_USE_SSL=false

# ===========================================
# MinIO Ports (for docker-compose)
# ===========================================

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===========================================
# Asynqmon Dashboard
# ===========================================

ASYNQMON_PORT=8081

# ===========================================
# OpenTelemetry Configuration
# ===========================================

# Enable distributed tracing (requires OTel Collector: make docker-observability)
TELEMETRY_ENABLED=false
# OTLP gRPC endpoint (default: localhost:4317)
TELEMETRY_OTLP_ENDPOINT=localhost:4317
# Use insecure gRPC connection (set to false with TLS-enabled collectors)
TELEMETRY_OTLP_INSECURE=true

# ===========================================
# Migration Database URLs (for staging/prod)
# ===========================================

# Set these when running migrations on staging/production
# STAGING_DATABASE_URL=postgres://user:pass@staging-host:5432/app?sslmode=require
# PROD_DATABASE_URL=postgres://user:pass@prod-host:5432/app?sslmode=require
