#!/bin/sh
#
# Pre-commit hook for Go projects
# Runs fast checks before allowing commit
#
# Install: make install-hooks
# Skip: git commit --no-verify

set -e

echo "Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get list of staged Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    echo "No Go files staged, skipping Go checks"
    exit 0
fi

# 1. Check formatting
echo "Checking formatting..."
UNFORMATTED=$(gofmt -l $STAGED_GO_FILES 2>&1 || true)
if [ -n "$UNFORMATTED" ]; then
    echo "${RED}The following files need formatting:${NC}"
    echo "$UNFORMATTED"
    echo ""
    echo "Run 'go fmt ./...' or 'make fmt' to fix"
    exit 1
fi
echo "${GREEN}Formatting OK${NC}"

# 2. Check for syntax errors (fast compile check)
echo "Checking for syntax errors..."
for file in $STAGED_GO_FILES; do
    if ! go build -o /dev/null "./${file%/*}" 2>/dev/null; then
        # Try individual file check
        if ! go vet "./$file" 2>/dev/null; then
            echo "${RED}Syntax error in: $file${NC}"
            exit 1
        fi
    fi
done
echo "${GREEN}Syntax OK${NC}"

# 3. Run go vet (fast static analysis)
echo "Running go vet..."
if ! go vet ./... 2>&1; then
    echo "${RED}go vet found issues${NC}"
    exit 1
fi
echo "${GREEN}go vet OK${NC}"

# 4. Run golangci-lint (fast mode) if available
if command -v golangci-lint > /dev/null 2>&1; then
    echo "Running golangci-lint (fast)..."
    if ! golangci-lint run --fast --new-from-rev=HEAD~1 2>&1; then
        echo "${YELLOW}Linter found issues (run 'make lint' for details)${NC}"
        # Don't fail on lint in pre-commit, just warn
    else
        echo "${GREEN}Lint OK${NC}"
    fi
fi

# 5. Check for common issues
echo "Checking for common issues..."

# Check for debug statements
if grep -r "fmt.Println\|fmt.Printf\|log.Print" --include="*.go" $STAGED_GO_FILES 2>/dev/null | grep -v "_test.go" | grep -v "// debug" > /dev/null; then
    echo "${YELLOW}Warning: Found debug print statements (consider removing before commit)${NC}"
fi

# Check for TODO/FIXME in new code
if git diff --cached $STAGED_GO_FILES | grep -E "^\+.*TODO|^\+.*FIXME" > /dev/null 2>&1; then
    echo "${YELLOW}Warning: New TODO/FIXME comments added${NC}"
fi

echo ""
echo "${GREEN}Pre-commit checks passed!${NC}"
exit 0
